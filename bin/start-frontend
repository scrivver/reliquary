#!/usr/bin/env bash
set -euo pipefail

if [ -z "${DATA_DIR:-}" ]; then
  echo "ERROR: DATA_DIR is not set. Are you in the dev shell? (nix develop)" >&2
  exit 1
fi

PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

tmux new-window -n frontend 2>/dev/null \
  || tmux new-session -d -s frontend -n frontend

tmux send-keys -t frontend "cd $PROJECT_ROOT/frontend && flutter run -d web-server --web-port=3000" Enter

echo "Frontend started in tmux window 'frontend'"
