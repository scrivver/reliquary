# MinIO credentials
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-in-production

# MinIO bucket name
MINIO_BUCKET=smartaffiliate

# Reliquary admin credentials (seeded on first startup)
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me-in-production

# JWT signing secret (must be unique and secret)
JWT_SECRET=change-me-in-production

# Server port
RELIQUARY_PORT=2080

# Worker configuration
THUMBNAIL_WORKERS=4
ARCHIVE_AFTER_DAYS=90
ARCHIVE_CHECK_HOURS=24
